{
  "name": "@mc-made/web-components",
  "version": "0.2.0-rc.1",
  "description": "Made's web component library",
  "type": "module",
  "types": "./dist/bundle.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:components && storybook build --output-dir build",
    "analyze": "cem analyze --globs \"packages/components/**/*.ts\" --exclude \"**/*.styles.ts\" --exclude \"**/stories/**\" --exclude \"**/test/**\" --litelement --outdir dist",
    "build:components": "npm run build:components-unix",
    "build:components-unix": "rm -Rf dist && tsc --project ./tsconfig.prod.json && npm run analyze && npm run make:dist -- --outdir dist && npm run bundle",
    "bundle": "node scripts/bundle.js",
    "build:components-windows": "cmd /c \"if exist dist (rmdir /s /q dist)\" && tsc --project ./tsconfig.prod.json && npm run analyze && npm run make:dist -- --outdir dist",
    "build:storybook": "storybook build",
    "build:component-styles": "node scripts/css-to-ts/component-styles.ts",
    "build:themes": "node scripts/css-to-ts/themes.js",
    "build:all-styles": "npm run build:themes && npm run build:component-styles",
    "build:icons": "node scripts/copy-system-icons.js --outdir dist",
    "create": "./scripts/run-create.sh",
    "dev": "npm run build:components && npm run storybook",
    "lint": "run-p lint:ts prettify:ts",
    "lint:ts": "eslint \"packages/**/*.ts\"",
    "make:dist": "node scripts/build.js",
    "prepare": "husky",
    "prettify:ts": "pretty-quick --pattern \"packages/**/*.ts\"",
    "storybook": "storybook dev -p 6006",
    "test": "echo \"Warn: no test specified\" && exit 0",
    "test:pre-push": "npm run build:components && NODE_OPTIONS=--max-old-space-size=4096 web-test-runner --group default --coverage",
    "test:component": "npm run build:components && web-test-runner -- --watch --group",
    "test:watch": "npm run build:components && web-test-runner --watch --group default"
  },
  "repository": {
    "type": "git",
    "url": "https://scm.forge.mastercard.com/projects/MDE/repos/unify-web-components"
  },
  "keywords": [
    "made",
    "unify",
    "web-components",
    "design-system",
    "lit"
  ],
  "author": "Made",
  "license": "ISC",
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.3",
    "@eslint/js": "^9.9.1",
    "@mc-made/css": "4.0.0-alpha.2",
    "@mc-made/design-tokens": "^3.0.0",
    "@mc-made/fonts": "3.0.0",
    "@mc-made/icons": "^2.1.1",
    "@open-wc/eslint-config": "^12.0.3",
    "@open-wc/lit-helpers": "^0.7.0",
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-a11y": "^8.2.9",
    "@storybook/addon-docs": "^8.2.9",
    "@storybook/addon-essentials": "^8.2.9",
    "@storybook/addon-links": "^8.2.9",
    "@storybook/web-components": "^8.2.9",
    "@storybook/web-components-vite": "^8.2.9",
    "@types/mocha": "^10.0.7",
    "@types/react": "^18.3.4",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@web/dev-server-esbuild": "^1.0.2",
    "@web/test-runner": "^0.18.3",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "^0.11.0",
    "custom-elements-manifest": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-chai-expect": "^3.1.0",
    "eslint-plugin-chai-friendly": "^1.0.1",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-lit": "^1.14.0",
    "eslint-plugin-lit-a11y": "^4.1.4",
    "eslint-plugin-sort-imports-es6-autofix": "^0.6.0",
    "eslint-plugin-wc": "^2.2.0",
    "fs-extra": "^11.2.0",
    "globals": "^15.9.0",
    "globby": "^14.0.2",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.10",
    "npm-run-all2": "^7.0.0",
    "pascal-case": "^4.0.0",
    "path": "^0.12.7",
    "plop": "^4.0.1",
    "postcss-lit": "^1.1.1",
    "prettier": "^3.3.3",
    "pretty-quick": "^4.0.0",
    "react": "^18.3.1",
    "sinon": "^18.0.0",
    "storybook": "^8.2.9",
    "strip-css-comments": "^5.0.0",
    "tslib": "^2.7.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.4.0",
    "unist-util-visit": "^5.1.0"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "eslint:recommended",
      "plugin:wc/recommended",
      "plugin:wc/best-practice",
      "plugin:lit/recommended",
      "plugin:lit-a11y/recommended"
    ],
    "plugins": [
      "@typescript-eslint",
      "wc",
      "lit",
      "lit-a11y",
      "chai-expect",
      "chai-friendly",
      "import",
      "sort-imports-es6-autofix"
    ],
    "env": {
      "es2021": true,
      "browser": true
    },
    "parserOptions": {
      "sourceType": "module"
    },
    "rules": {
      "no-unused-expressions": "off",
      "chai-friendly/no-unused-expressions": "error"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/bundle.d.ts",
      "import": "./dist/bundle.js"
    },
    "./bundle.js": "./dist/bundle.js",
    "./bundle.bundled.js": "./dist/bundle.bundled.js",
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js"
    },
    "./themes/*": "./dist/themes/*",
    "./utilities/*": "./dist/utilities/*",
    "./assets/*": "./dist/assets/*",
    "./react/*": "./dist/react/*",
    "./made-button.js": "./dist/components/button/made-button.js",
    "./made-input.js": "./dist/components/input/made-input.js",
    "./made-avatar.js": "./dist/components/avatar/made-avatar.js",
    "./made-badge.js": "./dist/components/badge/made-badge.js",
    "./made-icon.js": "./dist/components/icon/made-icon.js",
    "./made-link.js": "./dist/components/link/made-link.js",
    "./made-theme-provider.js": "./dist/components/theme-provider/made-theme-provider.js",
    "./made-checkbox.js": "./dist/components/checkbox/made-checkbox.js",
    "./made-toggle.js": "./dist/components/toggle/made-toggle.js",
    "./made-radio.js": "./dist/components/radio/made-radio.js",
    "./made-radio-group.js": "./dist/components/radio-group/made-radio-group.js",
    "./made-divider.js": "./dist/components/divider/made-divider.js",
    "./made-card.js": "./dist/components/card/made-card.js",
    "./made-card-media.js": "./dist/components/card/made-card-media.js",
    "./made-card-content.js": "./dist/components/card/made-card-content.js",
    "./made-card-actions.js": "./dist/components/card/made-card-actions.js",
    "./made-card-text.js": "./dist/components/card/made-card-text.js",
    "./made-icon-button.js": "./dist/components/icon-button/made-icon-button.js",
    "./made-tooltip.js": "./dist/components/tooltip/made-tooltip.js",
    "./made-loader.js": "./dist/components/loader/made-loader.js",
    "./made-modal.js": "./dist/components/modal/made-modal.js",
    "./made-textarea.js": "./dist/components/textarea/made-textarea.js",
    "./made-tabs.js": "./dist/components/tabs/made-tabs.js",
    "./made-tab.js": "./dist/components/tab/made-tab.js",
    "./made-tab-panel.js": "./dist/components/tab-panel/made-tab-panel.js",
    "./made-alert.js": "./dist/components/alert/made-alert.js",
    "./made-select.js": "./dist/components/select/made-select.js",
    "./made-otp.js": "./dist/components/otp/made-otp.js",
    "./made-progress-bar.js": "./dist/components/progress-bar/made-progress-bar.js",
    "./made-slider.js": "./dist/components/slider/made-slider.js",
    "./made-drawer.js": "./dist/components/drawer/made-drawer.js",
    "./made-sheet.js": "./dist/components/sheet/made-sheet.js",
    "./made-accordion.js": "./dist/components/accordion/made-accordion.js",
    "./made-accordion-item.js": "./dist/components/accordion-item/made-accordion-item.js",
    "./made-breadcrumb.js": "./dist/components/breadcrumb/made-breadcrumb.js",
    "./made-breadcrumb-item.js": "./dist/components/breadcrumb-item/made-breadcrumb-item.js"
  }
}
