{
  "name": "@mc-made/design-tokens",
  "version": "3.0.0",
  "description": "Design tokens by Made Framework",
  "owner": "Made",
  "type": "module",
  "main": "index.js",
  "files": [
    "docs",
    "themes"
  ],
  "scripts": {
    "test": "echo \"Warn: no test specified\" && exit 0",
    "build-primitives": "node scripts/build-primitives.js",
    "build-theme-unify-light": "node scripts/build-theme-unify-light.js",
    "build-theme-unify-dark": "node scripts/build-theme-unify-dark.js",
    "build-theme-mastercard-light": "node scripts/build-theme-mastercard-light.js",
    "build-theme-mastercard-dark": "node scripts/build-theme-mastercard-dark.js",
    "build-theme-partnerbank-light": "node scripts/build-theme-partnerbank-light.js",
    "build-theme-partnerbank-dark": "node scripts/build-theme-partnerbank-dark.js",
    "build-b2b-deprecated": "node scripts/build-b2b-deprecated-migration-map.js",
    "build-interface": "node scripts/build-interface.js",
    "split-tokens": "node scripts/split-tokens.js",
    "prebuild": "npm run split-tokens",
    "build": "node scripts/build-b2b-deprecated-migration-map.js && node scripts/build-theme-mastercard-light.js && node scripts/build-theme-mastercard-dark.js && node scripts/build-theme-unify-light.js && node scripts/build-theme-unify-dark.js && node scripts/build-interface.js",
    "postbuild": "cp package.json build/$(node -p \"require('./package.json').version\")/ && cp README.md build/$(node -p \"require('./package.json').version\")/ && cp -r docs build/$(node -p \"require('./package.json').version\")/",
    "figma-to-sd": "node ./tokens-b2b-deprecated/split-figma-tokens/figmaToSD.js",
    "copy-descriptions": "node scripts/copy-descriptions.js",
    "pack": "npm pack build/$(node -p \"require('./package.json').version\")/"
  },
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "style-dictionary": "^4.3.0",
    "@tokens-studio/sd-transforms": "./dependencies/sd-transforms-1.3.0.tgz"
  }
}
